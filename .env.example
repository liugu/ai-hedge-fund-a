# ========================================
# AI对冲基金 - 环境变量配置
# ========================================

# ========================================
# 财务数据API配置
# ========================================

# Financial Datasets API（美股数据）
# 从 https://financialdatasets.ai/ 获取API密钥
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# A股数据源配置（选择一个）
# 东方财富API - 免费开源
# 从 https://data.eastmoney.com/ 获取
EASTMONEY_API_KEY=your-eastmoney-api-key

# Tushare Pro API - 专业A股数据
# 从 https://tushare.pro/ 获取API密钥
TUSHARE_API_KEY=your-tushare-api-key

# AKShare - 免费开源财经数据接口（无需API密钥）
# pip install akshare

# ========================================
# LLM模型API配置
# ========================================

# OpenAI API（GPT-5等）
# 从 https://platform.openai.com/ 获取API密钥
OPENAI_API_KEY=your-openai-api-key

# Anthropic API（Claude-4-Sonnet、Claude-4.1-Opus等）
# 从 https://anthropic.com/ 获取API密钥
ANTHROPIC_API_KEY=your-anthropic-api-key

# DeepSeek API（DeepSeek-Chat、DeepSeek-Reasoner等）
# 从 https://deepseek.com/ 获取API密钥
DEEPSEEK_API_KEY=your-deepseek-api-key

# Groq API（DeepSeek、Llama3等）
# 从 https://groq.com/ 获取API密钥
GROQ_API_KEY=your-groq-api-key

# Google Gemini API（Gemini-2.5-Flash、Gemini-2.5-Pro）
# 从 https://ai.dev/ 获取API密钥
GOOGLE_API_KEY=your-google-api-key

# xAI API（Grok 4等）
XAI_API_KEY=your-xai-api-key

# Moonshot/Kimi API（Kimi-K2、Kimi-Latest、Moonshot-V1-*等）
# 从 https://platform.moonshot.ai/ 获取API密钥
# 中国大陆用户请设置：MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=your-moonshot-api-key

# GigaChat API
GIGACHAT_API_KEY=your-gigachat-api-key

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key

# Azure OpenAI API（GPT-4o、GPT-4o-mini等）
# 从 https://oai.azure.com/ 获取配置
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# ========================================
# A股特定配置
# ========================================

# 数据源选择：eastmoney / tushare / akshare
A_STOCK_DATA_SOURCE=akshare

# A股交易时间配置
A_STOCK_TRADING_HOURS_START=09:30
A_STOCK_TRADING_HOURS_END=15:00

# A股涨跌停限制（百分比）
A_STOCK_PRICE_LIMIT_PCT=10.0

# ST股票涨跌停限制（百分比）
A_STOCK_ST_PRICE_LIMIT_PCT=5.0

# 创业板/科创板涨跌停限制（百分比）
A_STOCK_GEM_PRICE_LIMIT_PCT=20.0